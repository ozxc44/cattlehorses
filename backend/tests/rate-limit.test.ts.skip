import assert from 'node:assert/strict';
import http from 'node:http';

process.env.NODE_ENV = 'test';
process.env.JWT_SECRET = 'rate-limit-test-secret';
process.env.AGENT_ONLINE_TTL_MS = '90000';
process.env.RATE_LIMIT_HEARTBEAT_PER_S = '0.1';
process.env.RATE_LIMIT_HEARTBEAT_BURST = '3';

async function main(): Promise<void> {
  const { AppDataSource } = await import('../src/data-source');
  const { _clearBuckets } = await import('../src/middleware/rate-limit.middleware');
  const app = (await import('../src/app')).default;
  await AppDataSource.initialize();
  const server = http.createServer(app);

  await new Promise<void>((resolve) => server.listen(0, resolve));
  const address = server.address();
  assert(address && typeof address === 'object');
  const baseUrl = `http://127.0.0.1:${address.port}`;

  try {
    _clearBuckets();

    const owner = await register(baseUrl, 'rl-owner');
    const project = await api(baseUrl, 'POST', '/v1/projects', owner.token, {
      name: 'Rate Limit Test',
      visibility: 'public',
    });
    assert.equal(project.status, 201);
    const projectId = project.data.id;

    const agentRes = await api(baseUrl, 'POST', `/v1/projects/${projectId}/agents`, owner.token, {
      name: 'RL Worker',
    });
    assert.equal(agentRes.status, 201);
    const agentKey = agentRes.data.api_key;

    // Under limit: 3 requests within burst should pass
    for (let i = 0; i < 3; i++) {
      const res = await apiWithKey(baseUrl, 'POST', '/v1/agents/heartbeat', agentKey, { status: 'active' });
      assert.equal(res.status, 200, `heartbeat ${i + 1} should pass`);
    }

    // Over limit: 4th request should get 429 with Retry-After
    const blocked = await apiWithKey(baseUrl, 'POST', '/v1/agents/heartbeat', agentKey, { status: 'active' });
    assert.equal(blocked.status, 429, '4th heartbeat should be rate limited');
    assert.ok(blocked.headers['retry-after'], 'Retry-After header must be present');
    assert.ok(parseInt(blocked.headers['retry-after'], 10) > 0, 'Retry-After must be positive');
    assert.deepEqual(blocked.data, { detail: 'Rate limit exceeded' });

    // Different agent should not be affected
    _clearBuckets();
    const agent2Res = await api(baseUrl, 'POST', `/v1/projects/${projectId}/agents`, owner.token, {
      name: 'RL Worker 2',
    });
    assert.equal(agent2Res.status, 201);
    const res2 = await apiWithKey(baseUrl, 'POST', '/v1/agents/heartbeat', agent2Res.data.api_key, { status: 'active' });
    assert.equal(res2.status, 200, 'different agent should not be rate limited');

    console.log('PASS: rate-limit tests passed');
  } finally {
    _clearBuckets();
    server.close();
    await AppDataSource.destroy();
  }
}

async function register(baseUrl: string, prefix: string): Promise<{ token: string; userId: string }> {
  const response = await api(baseUrl, 'POST', '/v1/auth/register', undefined, {
    email: `${prefix}-${Date.now()}-${Math.random().toString(16).slice(2)}@example.invalid`,
    password: 'RateLimit123!',
    display_name: prefix,
  });
  assert.equal(response.status, 201);
  return { token: response.data.access_token, userId: response.data.user.id };
}

async function api(
  baseUrl: string,
  method: string,
  path: string,
  token?: string,
  body?: unknown,
): Promise<{ status: number; data: any; headers: Record<string, string> }> {
  const headers: Record<string, string> = { 'Content-Type': 'application/json' };
  if (token) headers.Authorization = `Bearer ${token}`;
  const res = await fetch(`${baseUrl}${path}`, {
    method,
    headers,
    body: body ? JSON.stringify(body) : undefined,
  });
  const data = res.headers.get('content-type')?.includes('json') ? await res.json() : {};
  const respHeaders: Record<string, string> = {};
  res.headers.forEach((v, k) => { respHeaders[k] = v; });
  return { status: res.status, data, headers: respHeaders };
}

async function apiWithKey(
  baseUrl: string,
  method: string,
  path: string,
  apiKey: string,
  body?: unknown,
): Promise<{ status: number; data: any; headers: Record<string, string> }> {
  const headers: Record<string, string> = {
    'X-API-Key': apiKey,
    'Content-Type': 'application/json',
  };
  const res = await fetch(`${baseUrl}${path}`, {
    method,
    headers,
    body: body ? JSON.stringify(body) : undefined,
  });
  const data = res.headers.get('content-type')?.includes('json') ? await res.json() : {};
  const respHeaders: Record<string, string> = {};
  res.headers.forEach((v, k) => { respHeaders[k] = v; });
  return { status: res.status, data, headers: respHeaders };
}

main().catch((err) => {
  console.error('Rate limit test failed:', err);
  process.exit(1);
});
