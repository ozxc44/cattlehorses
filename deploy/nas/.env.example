# ──────────────────────────────────────────────────────────────────────────────
# Agent Collaboration OS — Environment Configuration
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# Then run: bash deploy/setup.sh
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (Postgres) ──
# Choose a strong password for the platform database.
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ── Security secrets ──
# Generate with: openssl rand -hex 32
# Used to sign JWT auth tokens. MUST be set to a random value.
JWT_SECRET=run-openssl-rand-hex-32-and-paste-here

# Secret for webhook signature verification (agent ↔ platform webhooks).
WEBHOOK_SECRET=run-openssl-rand-hex-32-and-paste-here

# Token for the debug-log API (optional but recommended).
DEBUG_LOG_API_TOKEN=run-openssl-rand-hex-32-and-paste-here

# ── Inbox lease (optional, defaults shown) ──
# How long an inbox item is leased to one poller before redelivery (ms).
# INBOX_LEASE_TTL_MS=300000

# ── Host (for CORS and public URLs) ──
# setup.sh auto-detects this. Override if behind a proxy or specific IP.
# PLATFORM_HOST=localhost

# ── Host data paths (optional, defaults shown) ──
# Where backend logs and project-git repos are stored.
# Defaults to ./data/ inside the deploy directory (portable, auto-created).
# Override to use a different disk:
# DEBUG_LOG_HOST_DIR=/your/path/logs
# PROJECT_GIT_HOST_DIR=/your/path/project-git

# ── Gitea/Forgejo (optional Git gateway) ──
# If you want the external Git gateway (clone/push/PR), set your host:
# GITEA_HOST=<your-platform-host>
# Data dir on host (default uses the compose volume):
# GITEA_DATA_DIR=/data_n004/forgejo/data
