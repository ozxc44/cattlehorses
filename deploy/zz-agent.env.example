# Copy to /etc/zhuzeyang-agent/backend.env and replace placeholder values.
# Do not commit real production secrets.

NODE_ENV=production
PORT=3000

# Public URL used by operators and CLI users.
PUBLIC_BASE_URL=http://127.0.0.1:18080/agent

# PostgreSQL connection.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=zz_agent
DB_PASSWORD=replace-with-production-db-password
DB_DATABASE=zz_agent
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Required in production. Generate a long random value outside this repository.
JWT_SECRET=replace-with-long-random-jwt-secret

# Optional outbound webhook HMAC secret if webhook delivery is enabled.
WEBHOOK_SECRET=replace-with-long-random-webhook-secret

# Background health monitor cadence.
HEALTH_CHECK_INTERVAL_MINUTES=5

# NAS / LAN debugging.
# Enable JSONL file logs when testing multiple agents on a LAN. Keep the file on
# persistent NAS storage and rotate it to avoid filling the volume.
LOG_LEVEL=info
DEBUG_LOG_ENABLED=false
DEBUG_LOG_HOST_DIR=/data/zz-agent-platform/logs
LOG_DIR=/var/log/zhuzeyang-agent
DEBUG_LOG_FILE=/var/log/zhuzeyang-agent/zz-agent-debug.jsonl
DEBUG_LOG_MAX_BYTES=20971520
DEBUG_LOG_MAX_FILES=5

# Optional operator-only log read API. Leave disabled on public deployments.
# When enabled, read recent logs with:
#   curl -H "X-Debug-Token: $DEBUG_LOG_API_TOKEN" \
#     "http://nas-ip:18080/agent/v1/debug/logs?lines=200"
DEBUG_LOG_API_ENABLED=false
DEBUG_LOG_API_TOKEN=replace-with-long-random-debug-token
